class Solution {
    public int[] nextGreaterElement(int[] nums1, int[] nums2) {
        // Map to store: element -> its next greater element
        Map<Integer, Integer> map = new HashMap<>();
        Stack<Integer> stack = new Stack<>();

        // Process nums2 to find next greater elements
        for (int num : nums2) {
            // While the current number is greater than the stack's top,
            // it is the "next greater" for the stack's top element.
            while (!stack.isEmpty() && stack.peek() < num) {
                map.put(stack.pop(), num);
            }
            stack.push(num);
        }

        // Build the result for nums1
        int[] ans = new int[nums1.length];
        for (int i = 0; i < nums1.length; i++) {
            // If the element wasn't in the map, it has no next greater (-1)
            ans[i] = map.getOrDefault(nums1[i], -1);
        }

        return ans;
    }
}
