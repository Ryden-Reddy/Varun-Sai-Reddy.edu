class Solution {
    public int majorityElement(int[] nums) {
        int count = 0;
        Integer candidate = null;

        for (int num : nums) {
            // If count is 0, we establish a new candidate
            if (count == 0) {
                candidate = num;
            }
            
            // If num matches candidate, increment; otherwise, decrement
            count += (num == candidate) ? 1 : -1;
        }

        return candidate;
    }
}
